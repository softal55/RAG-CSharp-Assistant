# Copy to ".env" in this folder and fill in your key (see Groq console).
# The real ".env" file is gitignored and will not be pushed.
#
# Warning: listing .env in pubspec assets bundles values into release builds.
# Do not ship store builds with a production key in assets; use CI secrets or
# --dart-define-from-file for release instead.
GROQ_API_KEY=
